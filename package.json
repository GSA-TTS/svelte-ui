{
  "name": "svelte-ui",
  "version": "0.1.0",
  "description": "Svelte UI component library with USWDS default styling and design system-agnostic flexibility",
  "type": "module",
  "scripts": {
    "parse:tokens": "tsx src/lib/token-generators/parse-tokens.ts",
    "generate:foundation": "tsx src/lib/token-generators/generate-foundation-tokens.ts",
    "generate:semantic": "tsx src/lib/token-generators/generate-semantic-tokens.ts",
    "generate:components": "tsx src/lib/token-generators/generate-component-tokens.ts",
    "generate:utilities": "tsx src/lib/token-generators/generate-utilities.ts",
    "generate:types": "echo 'TODO: implement type generation'",
    "generate:contrast": "echo 'TODO: implement contrast matrix generation'",
    "generate:all": "npm run parse:tokens && npm run generate:foundation && npm run generate:semantic && npm run generate:components && npm run generate:utilities && npm run generate:types && npm run generate:contrast",
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:storybook": "test-storybook"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/svelte-ui.es.js"
    },
    "./tokens/foundation/uswds/all.css": "./src/tokens/foundation/uswds/all.css",
    "./tokens/foundation/uswds/color.css": "./src/tokens/foundation/uswds/color.css",
    "./tokens/foundation/uswds/spacing.css": "./src/tokens/foundation/uswds/spacing.css",
    "./tokens/foundation/uswds/typesetting.css": "./src/tokens/foundation/uswds/typesetting.css",
    "./tokens/foundation/uswds/shadow.css": "./src/tokens/foundation/uswds/shadow.css",
    "./tokens/foundation/uswds/opacity.css": "./src/tokens/foundation/uswds/opacity.css",
    "./tokens/foundation/uswds/z-index.css": "./src/tokens/foundation/uswds/z-index.css",
    "./tokens/foundation/uswds/flex.css": "./src/tokens/foundation/uswds/flex.css",
    "./tokens/foundation/uswds/order.css": "./src/tokens/foundation/uswds/order.css",
    "./tokens/semantic/all.css": "./src/tokens/semantic/all.css",
    "./tokens/semantic/color.css": "./src/tokens/semantic/color.css",
    "./tokens/semantic/spacing.css": "./src/tokens/semantic/spacing.css",
    "./tokens/semantic/typesetting.css": "./src/tokens/semantic/typesetting.css",
    "./tokens/semantic/shadow.css": "./src/tokens/semantic/shadow.css",
    "./tokens/semantic/opacity.css": "./src/tokens/semantic/opacity.css",
    "./tokens/semantic/z-index.css": "./src/tokens/semantic/z-index.css",
    "./tokens/semantic/flex.css": "./src/tokens/semantic/flex.css",
    "./tokens/semantic/order.css": "./src/tokens/semantic/order.css",
    "./tokens/components/all.css": "./src/tokens/components/all.css",
    "./tokens/components/button.css": "./src/tokens/components/button.css",
    "./tokens/components/input.css": "./src/tokens/components/input.css",
    "./tokens/components/checkbox.css": "./src/tokens/components/checkbox.css"
  },
  "files": [
    "dist",
    "src/tokens",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "peerDependencies": {
    "svelte": "5.56.1"
  },
  "devDependencies": {
    "@storybook/svelte": "10.4.2",
    "@storybook/svelte-vite": "10.4.2",
    "@storybook/test-runner": "0.24.4",
    "@sveltejs/vite-plugin-svelte": "5.1.1",
    "@testing-library/svelte": "5.3.1",
    "@testing-library/user-event": "14.6.1",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "@uswds/uswds": "3.13.0",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.19.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "4.1.0",
    "sass": "1.83.4",
    "storybook": "10.4.2",
    "svelte": "5.56.1",
    "svelte-check": "4.5.0",
    "tslib": "2.8.1",
    "tsx": "4.19.2",
    "typescript": "6.0.3",
    "vite": "6.4.3",
    "vite-plugin-dts": "5.0.2",
    "vitest": "4.1.8"
  },
  "svelte": "./dist/svelte-ui.es.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "svelte",
    "component-library",
    "uswds",
    "design-system",
    "accessibility",
    "section-508",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gsa/svelte-ui"
  },
  "license": "CC0-1.0",
  "author": "GSA-TTSE",
  "engines": {
    "node": ">=26.3.0",
    "npm": ">=11.16.0"
  }
}
