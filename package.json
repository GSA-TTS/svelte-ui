{
  "name": "svelte-ui",
  "version": "0.1.0",
  "description": "Svelte UI component library with USWDS default styling and design system-agnostic flexibility",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:storybook": "test-storybook"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/svelte-ui.es.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "peerDependencies": {
    "svelte": "5.56.1"
  },
  "devDependencies": {
    "@storybook/svelte": "10.4.2",
    "@storybook/svelte-vite": "10.4.2",
    "@storybook/test-runner": "0.24.4",
    "@sveltejs/vite-plugin-svelte": "5.1.1",
    "@testing-library/svelte": "5.3.1",
    "@testing-library/user-event": "14.6.1",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.19.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "4.1.0",
    "storybook": "10.4.2",
    "svelte": "5.56.1",
    "svelte-check": "4.5.0",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vite": "6.4.3",
    "vite-plugin-dts": "5.0.2",
    "vitest": "4.1.8"
  },
  "svelte": "./dist/svelte-ui.es.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "svelte",
    "component-library",
    "uswds",
    "design-system",
    "accessibility",
    "section-508",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gsa/svelte-ui"
  },
  "license": "CC0-1.0",
  "author": "GSA-TTSE",
  "engines": {
    "node": ">=26.3.0",
    "npm": ">=11.16.0"
  }
}
