{
  "types": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "chore", "hidden": true },
    { "type": "docs", "section": "Documentation" },
    { "type": "style", "hidden": true },
    { "type": "refactor", "section": "Code Refactoring" },
    { "type": "perf", "section": "Performance Improvements" },
    { "type": "test", "hidden": true },
    { "type": "build", "hidden": true },
    { "type": "ci", "hidden": true }
  ],
  "commitUrlFormat": "https://github.com/GSA-TTS/svelte-ui/commit/{{hash}}",
  "compareUrlFormat": "https://github.com/GSA-TTS/svelte-ui/compare/{{previousTag}}...{{currentTag}}",
  "issueUrlFormat": "https://github.com/GSA-TTS/svelte-ui/issues/{{id}}",
  "userUrlFormat": "https://github.com/{{user}}"
}
